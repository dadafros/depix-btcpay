<template id="PixCheckout">
    <div class="payment-box text-center">
        <qrcode
            :value="model.invoiceBitcoinUrlQR"
            tag="img"
            :options="{ width: 256, margin: 1 }"
            class="img-fluid d-block mx-auto my-3"
        />
        <p class="mb-3">Para fazer o pagamento, aponte a câmera para o QR Code ou copie o PIX Copia e Cola</p>

        <div class="input-group mb-3">
            <label class="form-label text-uppercase text-muted small fw-semibold">
                PIX Copia e Cola
            </label>
            <span
                class="truncate-center-truncated me-3"
                :title="model.invoiceBitcoinUrl"
                data-bs-toggle="tooltip">
                <span class="truncate-center-start">
                    {{ model.invoiceBitcoinUrl.substring(0, 22) }}
                </span>
                <span class="truncate-center-end">
                    {{ model.invoiceBitcoinUrl.slice(-12) }}
                </span>
            </span>
            <button type="button"
                    class="btn btn-link d-flex p-0 clipboard-button text-body-secondary"
                    :data-clipboard="model.invoiceBitcoinUrl"
                    title="Copy">
                <svg width="18" height="18" aria-hidden="true" fill="currentColor">
                    <use href="/img/icon-sprite.svg#actions-copy"></use>
                </svg>
                <span class="visually-hidden">Copiar</span>
            </button>
        </div>

        <div v-if="model.simulateUrl" class="mt-3">
            <button
                type="button"
                class="btn btn-warning w-100"
                :disabled="simulating"
                v-on:click="simulate">
                {{ simulating ? 'Simulando...' : 'Simular pagamento (sandbox)' }}
            </button>
            <p v-if="simulateError" class="text-danger mt-2 small">{{ simulateError }}</p>
        </div>
    </div>
</template>

<script>
    Vue.component("PixCheckout", {
        props: ["model"],
        template: "#PixCheckout",
        data: function () {
            return { simulating: false, simulateError: null };
        },
        methods: {
            simulate: function () {
                this.simulating = true;
                this.simulateError = null;
                fetch(this.model.simulateUrl, { method: "POST" })
                    .then(function (res) {
                        if (!res.ok) throw new Error("HTTP " + res.status);
                    })
                    .catch(function (err) {
                        this.simulateError = "Erro ao simular: " + err.message;
                    }.bind(this))
                    .finally(function () {
                        this.simulating = false;
                    }.bind(this));
            }
        }
    });
</script>
