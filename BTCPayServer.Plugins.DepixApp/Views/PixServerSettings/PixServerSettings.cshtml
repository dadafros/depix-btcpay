@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Views.Server
@model BTCPayServer.Plugins.DepixApp.Data.Models.ViewModels.PixServerSettingsViewModel

@{
    ViewData["Title"] = "Pix Server Settings";
    ViewData.SetActivePage(
        activePage: "PixServerSettings",
        category: typeof(ServerNavPages).ToString(),
        title: "Pix Server Settings"
    );
}

<form method="post" asp-controller="PixServerSettings" asp-action="PixServerSettings">
    <div class="sticky-header d-flex align-items-center justify-content-between">
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <input type="submit" class="btn btn-primary" value="Save" />
    </div>

    <partial name="_StatusMessage" />

    <div class="row">
        <div class="col-md-8">

            <div class="form-group my-4">
                <label asp-for="ApiKey">DePix API Key (server)</label>
                <input asp-for="ApiKey" type="text" class="form-control" placeholder="sk_live_..." />
                <span asp-validation-for="ApiKey" class="text-danger"></span>

                <small class="form-text text-muted">
                    Stored encrypted. This configuration is used by stores that do not have their own store configuration (API key + webhook secret).
                </small>
            </div>

            <div class="form-group my-4">
                <label asp-for="WebhookSecret">Webhook Secret (server)</label>
                <input asp-for="WebhookSecret" type="text" class="form-control" placeholder="whsec_..." />
                <span asp-validation-for="WebhookSecret" class="text-danger"></span>

                @if (!string.IsNullOrEmpty(Model.WebhookSecretDisplay) && Model.WebhookSecretDisplay != "<not configured>")
                {
                    <small class="form-text text-muted">
                        Current: @Model.WebhookSecretDisplay — paste a new value to replace it.
                    </small>
                }
                else
                {
                    <small class="form-text text-muted">
                        Copy from the Merchant Area in the DePix App.
                    </small>
                }
            </div>

            @if (Model.ApiKeyConfigured)
            {
                <div class="card my-4">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <span>Webhook</span>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Copy this webhook URL and paste it in the DePix App: Menu → Lojista → Minha Conta → Configurações avançadas → Callback URL.
                        </p>

                        <div class="form-group mb-3">
                            <label asp-for="WebhookUrl">Webhook URL</label>
                            <div class="input-group">
                                <input asp-for="WebhookUrl" class="form-control" id="WebhookUrl" readonly />
                                <button type="button" class="btn btn-outline-secondary" data-clipboard-target="#WebhookUrl">
                                    Copy
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning my-4">
                    Set the DePix API key and webhook secret, then click Save.
                </div>
            }
        </div>
    </div>
</form>
