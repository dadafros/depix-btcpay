@using BTCPayServer
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.Depix
@model BTCPayServer.Plugins.Depix.Data.Models.ViewModels.PixStoreViewModel

@{
    #nullable enable

    WalletId? walletId = null;
    var queryWalletId = Context.Request.Query["walletId"].ToString();
    if (!string.IsNullOrEmpty(queryWalletId) && WalletId.TryParse(queryWalletId, out var parsedWalletId))
        walletId = parsedWalletId;

    ViewData.SetActivePage(
        activePage: "PixSettings",
        category: DePixPlugin.PluginNavKey,
        title: "Pix Settings",
        activeId: walletId?.ToString() ?? "PixSettings"
    );

    var hasAnyEffectiveConfig = Model.IsStoreCfgValid || Model.EffectiveUsesServerConfig;
}

<form method="post" asp-action="PixSettings" asp-route-walletId="@(walletId?.ToString())">
    <div class="sticky-header d-flex align-items-center justify-content-between">
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <input type="submit" class="btn btn-primary" value="Save" />
    </div>

    <partial name="_StatusMessage" />

    <div class="row">
        <div class="col-md-8">

            @if (Model.EffectiveUsesServerConfig && !Model.IsStoreCfgValid)
            {
                <div class="alert alert-info my-4">
                    A <strong>server-level DePix configuration</strong> is available.
                    If you do not configure for this store, the server configuration will be used.
                </div>
            }

            <div class="form-group my-4">
                <label asp-for="ApiKey">DePix API Key</label>
                <input asp-for="ApiKey" type="text" class="form-control" placeholder="sk_live_..." />
                <span asp-validation-for="ApiKey" class="text-danger"></span>

                <small class="form-text text-muted">
                    Don't have an API key? Create one at
                    <a href="https://depixapp.com/btcpay" target="_blank" rel="noopener noreferrer">
                        depixapp.com/btcpay
                    </a>.
                    <br />
                    If this server is configured by the server admin, you may not need to set a store API key.
                </small>
            </div>

            <div class="form-group my-4">
                <label asp-for="WebhookSecret">Webhook Secret</label>
                <input asp-for="WebhookSecret" type="text" class="form-control" placeholder="whsec_..." />
                <span asp-validation-for="WebhookSecret" class="text-danger"></span>

                @if (!string.IsNullOrEmpty(Model.WebhookSecretDisplay))
                {
                    <small class="form-text text-muted">
                        Current: @Model.WebhookSecretDisplay — paste a new value to replace it.
                    </small>
                }
                else
                {
                    <small class="form-text text-muted">
                        Copy from the Merchant Area in the DePix App.
                    </small>
                }
            </div>

            @if (hasAnyEffectiveConfig)
            {
                <div class="my-4">
                    <label class="d-flex align-items-center">
                        <input asp-for="IsEnabled" type="checkbox" class="btcpay-toggle me-2" />
                        <span>Enable Pix</span>
                    </label>
                </div>

                <div class="card my-4">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <span>Webhook</span>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Copy this webhook URL and configure it in the DePix App Merchant Area.
                        </p>

                        <div class="form-group mb-3">
                            <label asp-for="WebhookUrl">Webhook URL</label>
                            <div class="input-group">
                                <input asp-for="WebhookUrl" class="form-control" id="WebhookUrl" readonly />
                                <button type="button" class="btn btn-outline-secondary"
                                        data-clipboard-target="#WebhookUrl">
                                    Copy
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning my-4">
                    DePix is not configured. Enter your API key and webhook secret, then click Save.
                    Alternatively, ask the server administrator to configure DePix at the server level.
                </div>
            }
        </div>
    </div>
</form>
